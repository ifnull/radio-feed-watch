# Copy to .env and fill in. Never commit .env.

# Broadcastify listen stream (default) — Basic auth only, no developer API approval
BROADCASTIFY_USERNAME=
BROADCASTIFY_PASSWORD=

# Optional: Broadcastify Calls API (mode: calls) — requires approved developer app
# https://www.broadcastify.com/developer
BROADCASTIFY_API_KEY_ID=
BROADCASTIFY_API_KEY_SECRET=
BROADCASTIFY_APP_ID=

# Optional cloud STT (only when stt.provider: deepgram)
DEEPGRAM_API_KEY=

# Optional LLM transcript correction (llm_correct.enabled: true)
# Any OpenAI-compatible key (OpenAI, Groq, OpenRouter, local proxy, …)
OPENAI_API_KEY=

# Optional MQTT (Home Assistant broker)
MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC_PREFIX=radio
